graph TB
  classDef entry fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
  classDef runtime fill:#fffde7,stroke:#f9a825,stroke-width:2px
  classDef core fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
  classDef infra fill:#ffebee,stroke:#c62828,stroke-width:2px
  
  subgraph ENTRY["Entry Points"]
    EXT[External System]
    UI[Admin UI]
    EVT[S3 Event]
  end
  
  subgraph RUNTIME["p981-runtime"]
    API[REST API]
    WATCH[Event Watcher]
    JOB[Job Store]
    SCHED[Scheduler]
    WORKER[Worker Pool]
    RETRY[Retry Handler]
    DLQ[Dead Letter Queue]
    DLQMON[DLQ Monitor]
    NOTIFY[Notification Service]
    MON[Monitoring Logging]
    ADAPTERS[Adapters]
  end
  
  subgraph CORE["p981-core"]
    EXEC[Stage Executor]
    DISC[Discover Stage Definition]
    SYN[Synthesize Stage Definition]
    PORTS[Ports]
  end
  
  subgraph INFRA["Infrastructure"]
    OBJ[Object Storage]
    META[Metadata DB]
    INDEX[Asset Index]
    CACHE[Cache Layer]
    OBS[Observability]
  end
  
  EXT -->|request| API
  UI -->|request| API
  EVT -->|event| WATCH
  API -->|job| JOB
  WATCH -->|job| JOB
  JOB -->|dispatch| SCHED
  SCHED -->|assign| WORKER
  WORKER -->|run| EXEC
  EXEC -->|use| DISC
  EXEC -->|use| SYN
  WORKER -->|update| JOB
  WORKER -->|fail| RETRY
  RETRY -->|retry| JOB
  RETRY -->|giveup| DLQ
  DLQ -->|event| DLQMON
  DLQMON -->|notify| NOTIFY
  JOB -->|complete| NOTIFY
  WORKER -->|metrics| MON
  PORTS -->|implemented by| ADAPTERS
  ADAPTERS -->|blob| OBJ
  ADAPTERS -->|meta| META
  ADAPTERS -->|index| INDEX
  ADAPTERS -->|cache| CACHE
  ADAPTERS -->|obs| OBS
  
  class EXT,UI,EVT entry
  class RUNTIME,API,WATCH,JOB,SCHED,WORKER,RETRY,DLQ,DLQMON,NOTIFY,MON,ADAPTERS runtime
  class CORE,EXEC,DISC,SYN,PORTS core
  class INFRA,OBJ,META,CACHE,OBS infra
