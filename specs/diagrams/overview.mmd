graph TB
  classDef entry fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000
  classDef core fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
  classDef runtime fill:#fffde7,stroke:#f9a825,stroke-width:2px,color:#000
  classDef infra fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#000

  subgraph ENTRY["Entry Points / Clients"]
    CLI[CLI Tool]
    API[API Clients]
    GUI[GUI Clients]
    EVT[Event Sources]
  end

  subgraph SYSTEM["Portrait981 System"]
    CORE_APP[p981-core<br/>Core App]
    CORE[p981-core<br/>Stages + Domain Logic]
    RUNTIME[p981-runtime<br/>API + Jobs + Workers]
    BACKENDS[Backends / Protocols]
  end

  subgraph INFRA["Infrastructure"]
    OBJ[(Object Storage)]
    META[(Metadata DB)]
    INDEX[(Asset Index)]
    JOB[(Job Store / Queue)]
    OBS[(Observability)]
  end

  CLI -->|dev execute| CORE_APP
  API -->|request| RUNTIME
  EVT -->|event| RUNTIME
  RUNTIME -->|execute| CORE_APP
  CORE_APP -->|run| CORE
  CORE -->|via protocols| BACKENDS
  BACKENDS -->|blob| OBJ
  BACKENDS -->|meta| META
  BACKENDS -->|index| INDEX
  RUNTIME -->|job state| JOB
  RUNTIME -->|metrics/logs| OBS
  BACKENDS -->|obs| OBS

  class CLI,API,GUI,EVT entry
  class CORE,CORE_APP core
  class RUNTIME runtime
  class BACKENDS runtime
  class INFRA,OBJ,META,INDEX,JOB,OBS infra
